#% for instance in claude_instances | default([]) %#
---
apiVersion: helm.toolkit.fluxcd.io/v2
kind: HelmRelease
metadata:
  name: #{instance}#
  namespace: claudecode
spec:
  chartRef:
    kind: OCIRepository
    name: claude-code
  interval: 1h
  values:
    controllers:
      #{instance}#:
        strategy: Recreate
        # Client remote-support terminal: off by default. Scale to 1 only
        # while actively supporting this client, to minimize the standing
        # exposure window of a LAN-facing shell with network-scanning
        # capability (see securityContext.capabilities below).
        replicas: 0
        containers:
          app:
            image:
              repository: ghcr.io/ferry133/claude-code
              tag: 8328b34
            env:
              TTYD_CREDENTIAL:
                valueFrom:
                  secretKeyRef:
                    name: claude-code-secret
                    key: TTYD_CREDENTIAL
            probes:
              liveness:
                enabled: true
                custom: true
                spec:
                  tcpSocket:
                    port: 7681
                  initialDelaySeconds: 15
                  periodSeconds: 30
                  timeoutSeconds: 5
                  failureThreshold: 3
              readiness:
                enabled: true
                custom: true
                spec:
                  tcpSocket:
                    port: 7681
                  initialDelaySeconds: 15
                  periodSeconds: 30
                  timeoutSeconds: 5
                  failureThreshold: 3
            securityContext:
              allowPrivilegeEscalation: false
              capabilities:
                drop: ["ALL"]
                add: ["NET_RAW"] # nmap/masscan/arp-scan/tcpdump/fping raw sockets
            resources:
              requests:
                cpu: 100m
                memory: 256Mi
              limits:
                memory: 1Gi
    persistence:
      claude-config:
        type: persistentVolumeClaim
        storageClass: sc-nas
        accessMode: ReadWriteOnce
        size: 5Gi
        globalMounts:
          - path: /home/claude/.claude
      claude-workspace:
        type: persistentVolumeClaim
        storageClass: sc-nas
        accessMode: ReadWriteOnce
        size: 20Gi
        globalMounts:
          - path: /home/claude/workspace
      coding:
        type: nfs
        server: "${NAS_SERVER}"
        path: "${NAS_CODING_PATH}"
        globalMounts:
          - path: /home/claude/coding
    defaultPodOptions:
      hostNetwork: true
      dnsPolicy: ClusterFirstWithHostNet
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        runAsGroup: 1000
      labels:
        hostnetwork-group: claude-code
      # hostNetwork pods all bind :7681 on the node -- hard-require spreading
      # across nodes so this and any other claude-code/instance never collide
      # (including the base claude-code app and multiple claude_instances on
      # the same client).
      affinity:
        podAntiAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            - labelSelector:
                matchLabels:
                  hostnetwork-group: claude-code
              topologyKey: kubernetes.io/hostname
    service:
      app:
        ports:
          http:
            port: 7681
    route:
      app:
        hostnames: ["#{instance}#.${SECRET_DOMAIN}"]
        parentRefs:
          - name: envoy-external
            namespace: network
            sectionName: https
        rules:
          - backendRefs:
              - identifier: app
                port: 7681
#% endfor %#
