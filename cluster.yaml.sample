---
# cluster.yaml.sample — per-cluster configuration
# Copy to cluster.yaml, fill in values, then run: task configure
# cluster.yaml is gitignored and never committed.

# ── Network ───────────────────────────────────────────────────────────────────
node_cidr: "10.x.x.0/24"            # subnet for node IPs
node_default_gateway: "10.x.x.1"    # router IP
node_dns_servers:
  - "1.1.1.1"
node_ntp_servers:
  - "time.cloudflare.com"
# node_vlan_tag: "10"               # optional VLAN tag

cluster_pod_cidr: "10.42.0.0/16"    # default, change if overlaps
cluster_svc_cidr: "10.43.0.0/16"    # default, change if overlaps

cluster_api_addr: "10.x.x.x"               # VIP or first controller IP
cluster_gateway_addr: "10.x.x.x"           # envoy-external LB IP
cluster_dns_gateway_addr: "10.x.x.x"       # k8s-gateway (DNS) LB IP
cloudflare_gateway_addr: "10.x.x.x"        # envoy-internal LB IP

# ── Cloudflare ────────────────────────────────────────────────────────────────
cloudflare_domain: "example.com"
cloudflare_token: ""                 # API token (DNS edit permission)

# ── Repository ────────────────────────────────────────────────────────────────
repository_name: "ferry133/jg-base"
# repository_branch: "main"
# repository_visibility: "public"

# ── NAS (optional, required for extras/storage/nfs-subdir and extras/claude-code) ──
# nas_server: "10.x.x.x"
# nas_path: "/volume/path"          # NFS export for storage provisioner (sc-nas)
# nas_coding_path: "/volume/coding" # NFS export for claude-code coding workspace

# ── Claude Code (optional, required for extras/claude-code) ───────────────────
# claude_instances:
#   - "cc"
#   - "trello"
# ttyd_credential: "user:password"  # ttyd basic auth
